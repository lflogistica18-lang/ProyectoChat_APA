    {
      "parameters": {
        "jsCode": "const agentOutput = $('🧠 AI Sales Agent').item.json.output || '';\nconst userInput = $('🔄 Normalizar Entrada').item.json;\n\n// Extraer bloque JSON de la respuesta del agente\nconst jsonMatch = agentOutput.match(/```json\\s*([\\s\\S]*?)```/);\n\nif (jsonMatch && jsonMatch[1]) {\n  try {\n    const leadData = JSON.parse(jsonMatch[1].trim());\n    if (leadData.lead_completo === true) {\n      return [{\n        json: {\n          ...leadData,\n          telefono_wa: userInput.phone,\n          nombre_contacto_wa: userInput.contact_name,\n          timestamp: new Date().toLocaleString('es-AR', { timeZone: 'America/Argentina/Buenos_Aires' }),\n          es_lead_completo: true\n        }\n      }];\n    }\n  } catch(e) {\n    // JSON inválido, no es lead completo\n  }\n}\n\nreturn [{\n  json: {\n    es_lead_completo: false,\n    telefono_wa: userInput.phone\n  }\n}];"
      },
